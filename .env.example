# Claude Code Learnable Deck local model settings
# Copy to .env and edit the model names to match `ollama list` on your machine.

# Ollama / Anthropic-compatible endpoint used by Claude Code.
ANTHROPIC_AUTH_TOKEN=ollama
ANTHROPIC_BASE_URL=http://localhost:11434

# Optional Claude CLI binary name/path.
LLD_CLAUDE_BIN=claude

# Set to 1 when you want scripts to call Claude Code non-interactively.
# Leave 0 to use the deterministic local fallback pipeline.
LLD_USE_CLAUDE=0

# If Claude Code fails or returns invalid JSON, fall back to deterministic local logic.
# Set to 0 if you want such failures to stop the run.
LLD_CLAUDE_FALLBACK_ON_ERROR=1
LLD_CLAUDE_MAX_BUFFER=50000000
LLD_MAX_SOURCE_CHARS=20000

# Model profile: gemma4_31b_thinking | gpt_oss_120b | qwen3_coder_next | direct
LLD_MODEL_PROFILE=qwen3_coder_next

# Actual Ollama model names. Adjust these to your local tags.
LLD_MODEL_GEMMA4_31B_THINKING=gemma4:31b-thinking
LLD_MODEL_GPT_OSS_120B=gpt-oss:120b
LLD_MODEL_QWEN3_CODER_NEXT=qwen3-coder-next

# Use this only when LLD_MODEL_PROFILE=direct.
LLD_MODEL_DIRECT=qwen3-coder-next

# Optional role-specific overrides. If empty, LLD_MODEL_PROFILE is used.
LLD_BUILDER_MODEL_PROFILE=
LLD_CRITIC_MODEL_PROFILE=

# Fixed iteration defaults.
LLD_DEFAULT_MAX_ROUNDS=50
LLD_OUTPUT_LANGUAGE=ja
LLD_TARGET_SLIDE_COUNT=auto
LLD_AUDIENCE=日本語で学ぶセキュリティエンジニア
LLD_DURATION_MINUTES=15

# PDF support is optional and uses the `pdftotext` command when available.
LLD_PDF_MAX_BUFFER=50000000

# Set to 1 to run Marp CLI PDF/PPTX export after slides.md is generated.
# Keeping this disabled by default makes the scaffold runnable without browser dependencies.
LLD_RUN_MARP_EXPORT=0
